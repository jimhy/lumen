# Lumen Server 生产环境配置。
# 拷到 /etc/lumen-server/lumen-server.env 并逐项改（尤其 CHANGE_ME）。
# 服务端启动时自动幂等建表（CREATE TABLE IF NOT EXISTS），无需手动 SQL。

# —— 监听 ——
# TCP：WebSocket 中继 + REST API。前置 Caddy 反代终止 TLS，故绑本机/内网即可。
LUMEN_BIND_ADDR=127.0.0.1:8787
# UDP：M6 P2P 打洞 STUN 反射端。**必须公网直接可达**（不能走反代 / 负载均衡）。
LUMEN_STUN_BIND_ADDR=0.0.0.0:8788

# —— 数据库（生产 Postgres）——
# 服务端启动自动建表；用 127.0.0.1 走 IPv4。sslmode 按需（当前连接为 NoTls）。
LUMEN_DATABASE_URL=postgres://lumen_user:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/lumen?sslmode=disable

# —— 安全 ——
# JWT 签名密钥，**必须**改为强随机（生成：openssl rand -hex 32）。
LUMEN_JWT_SECRET=CHANGE_ME_run__openssl_rand_hex_32
# token 有效期（秒），默认 7 天。
LUMEN_TOKEN_TTL_SECS=604800

# —— 其它 ——
# 设备在线判定窗口（秒）。
LUMEN_ONLINE_WINDOW_SECS=120
# 日志级别（tracing EnvFilter：error / warn / info / debug）。
LUMEN_LOG=info
